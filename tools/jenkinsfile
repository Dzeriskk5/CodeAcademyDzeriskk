pipeline {
    agent any

    stages {
        stage('Hello') {
            steps {
                echo 'Hello World'
            }
        }
        stage('Check Docker') {
            steps {
                script {
                    // Check if Docker is installed
                    def dockerCheck = sh(script: 'which docker || echo "not found"', returnStdout: true).trim()
                    
                    if (dockerCheck == "not found") {
                        echo 'Docker not found, installing...'
                        sh '''
                            sudo apt-get update
                            sudo apt-get install -y docker.io
                        '''
                    } else {
                        echo 'Docker is already installed'
                    }
                }
            }
        }
        stage('Docker Login') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'b91ccd61-788f-4cb4-92d9-fc89325337b6', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh 'docker login -u $DOCKER_USER -p $DOCKER_PASS'
                    }
                }
            }
        }
    }
}
